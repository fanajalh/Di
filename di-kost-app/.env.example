# Di Kost App - Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
API_URL=https://api.example.com
API_KEY=your_api_key_here
API_TIMEOUT=10000

# App Configuration
APP_NAME=Di - Sewa Kost Premium
APP_VERSION=1.0.0
BUILD_NUMBER=1

# Feature Flags
ENABLE_DEBUG=false
ENABLE_CRASH_REPORTING=true
ENABLE_ANALYTICS=true

# Firebase (if using Firebase)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Payment Integration (if using Stripe/Midtrans)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
MIDTRANS_SERVER_KEY=

# Chat Integration (if using Firebase/Socket.io)
SOCKET_IO_URL=

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Other
ENVIRONMENT=development
MOCK_DATA=true
